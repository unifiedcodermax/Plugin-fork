# Copy to .env and fill in for local development.
# Never commit .env — only this template.

PLANARA_ENV=dev
PLANARA_HOST=127.0.0.1
PLANARA_PORT=8765
PLANARA_LOG_LEVEL=INFO

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
PLANARA_JWT_SECRET=change-me-in-production
PLANARA_JWT_TTL_MINUTES=480

PLANARA_DB_URL=sqlite:///./planara.db
